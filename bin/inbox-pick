#!/usr/bin/env bash
# bin/inbox-pick — open the picker (display-popup → choose-tree).
#
# Bound by tmux-coding-agents.tmux to `prefix + <pick-key>`.
#
# Behavior:
#   - if hooks not installed → display-message pointing to install-hooks; exit
#   - if no tracked panes   → display-message "no Claude sessions tracked yet"
#   - else: build the filter expression for choose-tree and exec it
#
# Sort order: waiting first (by recency), working next, idle last.
# Native preview is on by default (choose-tree's `v` toggles).

set -uo pipefail

PLUGIN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
. "$PLUGIN_ROOT/lib/state.sh"
# shellcheck disable=SC1091
. "$PLUGIN_ROOT/lib/render.sh"

SETTINGS="${CLAUDE_SETTINGS:-$HOME/.claude/settings.json}"

# Quick check: are our hooks wired? Use a sentinel file to avoid re-parsing
# settings.json on every keypress (cached after first successful install).
hooks_installed() {
  local cache_dir tag mtime_settings mtime_tag
  cache_dir="$(state::cache_dir)" 2>/dev/null || return 1
  tag="$cache_dir/.hooks-installed"
  if [ -r "$tag" ] && [ -r "$SETTINGS" ]; then
    mtime_settings="$(date -r "$SETTINGS" +%s 2>/dev/null || stat -c %Y "$SETTINGS" 2>/dev/null || echo 0)"
    mtime_tag="$(cat "$tag" 2>/dev/null || echo 0)"
    case "$mtime_tag" in *[!0-9]* | '') mtime_tag=0 ;; esac
    if [ "$mtime_tag" -ge "$mtime_settings" ]; then
      return 0
    fi
  fi
  if [ -r "$SETTINGS" ] \
    && command -v jq >/dev/null 2>&1 \
    && jq -e '
       (.hooks // {}) | to_entries | any(.value | type == "array" and any(
         .hooks // [] | any(.command // "" | contains("tmux-coding-agents/bin/hook"))))
     ' "$SETTINGS" >/dev/null 2>&1; then
    # Cache the verification.
    if [ -n "$cache_dir" ]; then
      mtime_settings="$(date -r "$SETTINGS" +%s 2>/dev/null || stat -c %Y "$SETTINGS" 2>/dev/null || echo 0)"
      printf '%s' "$mtime_settings" >"$tag" 2>/dev/null || true
    fi
    return 0
  fi
  return 1
}

if ! hooks_installed; then
  tmux display-message "tmux-coding-agents: hooks not installed — run: $PLUGIN_ROOT/bin/install-hooks"
  exit 0
fi

# Get current tracked panes (sorted: waiting > working > idle).
#
# SECURITY (review wwbo2gfgl CRITICAL): every row is filtered through a strict
# `^%[0-9]+$` regex on the pane_id column. A row with a malformed pane_id is
# dropped (and logged via debug if enabled) rather than processed, because the
# pane_id is interpolated into tmux format strings further down. State.sh
# already validates writes, so this is defense in depth against any future
# regression that lets a bad value through.
rows="$(state::read 2>/dev/null \
  | awk -F'\t' '$1 ~ /^%[0-9]+$/' || true)"
if [ -z "$rows" ]; then
  tmux display-message "tmux-coding-agents: no Claude sessions tracked yet"
  exit 0
fi

# Lazy GC of stale rows: drop entries whose pane no longer exists in any tmux
# session. DESIGN §4 / §6.4 / §10 require this be a REAL state.tsv rewrite,
# not just an in-memory filter — so a tmux restart eventually empties the TSV
# instead of accumulating dead rows forever.
#
# We pipe `tmux list-panes` straight into state::gc_panes, which atomically
# rewrites state.tsv under LOCK_EX dropping any row whose pane_id is not in
# the live set. Then re-read.
live_pane_ids="$(tmux list-panes -as -F '#{pane_id}' 2>/dev/null \
  | awk '/^%[0-9]+$/')"
if [ -n "$live_pane_ids" ]; then
  printf '%s\n' "$live_pane_ids" | state::gc_panes 2>/dev/null || true
  rows="$(state::read 2>/dev/null \
    | awk -F'\t' '$1 ~ /^%[0-9]+$/' || true)"
fi
if [ -z "$rows" ]; then
  tmux display-message "tmux-coding-agents: no Claude sessions tracked yet"
  exit 0
fi

# Build a sorted list of pane_ids, with sort-key prefixed (status rank, then
# since_epoch desc). Pipe through awk → sort → cut.
sorted_pane_ids="$(
  printf '%s\n' "$rows" \
    | awk -F'\t' '{
        # rank: 0 waiting, 1 working, 2 idle/other
        s = $3
        if (s == "waiting") r = 0
        else if (s == "working") r = 1
        else r = 2
        # secondary: newer first (use 9999999999 - epoch for ascending sort)
        inv = 9999999999 - $4
        printf "%d\t%010d\t%s\n", r, inv, $1
      }' \
    | sort -t$'\t' -k1,1n -k2,2n \
    | cut -f3
)"

if [ -z "$sorted_pane_ids" ]; then
  tmux display-message "tmux-coding-agents: no Claude sessions tracked yet"
  exit 0
fi

# Build a filter for choose-tree:  -f '#{||:#{==:#{pane_id},%17},#{==:#{pane_id},%18}}'
# Compose iteratively to handle ≥1 panes safely.
#
# SECURITY: each pid is re-validated against the strict pattern before
# interpolation into the tmux format string. Belt-and-suspenders with the
# state::read filter above.
filter=""
while IFS= read -r pid; do
  [ -n "$pid" ] || continue
  # Bash regex matches arbitrary-length pane_ids (long-uptime tmux servers
  # can allocate %100000+, which a fixed-width case-glob would silently drop).
  [[ "$pid" =~ ^%[0-9]+$ ]] || continue
  local_eq="#{==:#{pane_id},${pid}}"
  if [ -z "$filter" ]; then
    filter="$local_eq"
  else
    filter="#{||:${filter},${local_eq}}"
  fi
done <<<"$sorted_pane_ids"

# Format string for each row. We embed our render::row output as a tmux format
# fragment by walking the rows and producing a -F template. Since choose-tree
# evaluates the format per-pane, we need ONE template that pulls dynamic data
# from the running pane AND merges our state info. We pre-compute a per-pane
# format key by setting a tmux user-option @inbox-row-<pane_id> from this
# script, then reference it.
#
# Each option holds the rendered row content for its pane, scrubbed.
#
# Leak prevention: on every invocation, first unset every existing
# @inbox-row-* option that doesn't correspond to a currently-tracked pane.
# Without this, options accumulate forever as panes come and go.

# Unset stale @inbox-row-* options. show-options -g matches the literal "-g"
# scope; tr -d strips quoting, awk extracts keys, set-option -u removes.
tmux show-options -g 2>/dev/null \
  | awk '/^@inbox-row-/ {print $1}' \
  | while IFS= read -r opt; do
    [ -n "$opt" ] || continue
    # Compute the pane_id portion (strip "@inbox-row-" prefix).
    opt_pane="${opt#@inbox-row-}"
    # Keep only options whose pane is still in $sorted_pane_ids.
    case $'\n'"$sorted_pane_ids"$'\n' in
      *$'\n'"$opt_pane"$'\n'*) : ;; # still tracked → keep
      *) tmux set-option -gu "$opt" 2>/dev/null || true ;;
    esac
  done

now_epoch="$(date +%s)"
while IFS=$'\t' read -r pane_id _kind status since_epoch _pid project _tpath; do
  [ -n "${pane_id:-}" ] || continue
  # Strict re-validation, arbitrary-length digits.
  [[ "$pane_id" =~ ^%[0-9]+$ ]] || continue
  age=$((now_epoch - since_epoch))
  rendered="$(render::row "$status" "$project" "$age")"
  # Set as a per-pane user option (works on tmux 3.2+).
  tmux set-option -gq "@inbox-row-${pane_id}" "$rendered" 2>/dev/null || true
done <<<"$rows"

# Use that per-pane option in the format string.
fmt='#{?#{pane_in_mode},,}#{E:@inbox-row-#{pane_id}}'

# SECURITY (review wwbo2gfgl CRITICAL): pass the choose-tree command as ARGV
# (separate args), not as a single shell-parsed string. With the previous
# string form, `tmux display-popup -E "tmux choose-tree -Zw -f '$filter' ..."`
# spawned a child sh which re-parsed the string — a `'` inside $filter (e.g.,
# from a malicious pane_id) closed the single-quote and ran arbitrary code.
# argv form bypasses the inner shell entirely.
exec tmux display-popup -E -h 70% -w 80% \
  tmux choose-tree -Zs -f "$filter" -F "$fmt"
