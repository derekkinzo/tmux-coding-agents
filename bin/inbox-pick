#!/usr/bin/env bash
# bin/inbox-pick — open the picker (display-popup → choose-tree).
#
# Bound by tmux-coding-agents.tmux to `prefix + <pick-key>`.
#
# Behavior:
#   - if hooks not installed → display-message pointing to install-hooks; exit
#   - if no tracked panes   → display-message "no Claude sessions tracked yet"
#   - else: build the filter expression for choose-tree and exec it
#
# Sort order: waiting first (by recency), working next, idle last.
# Native preview is on by default (choose-tree's `v` toggles).

set -uo pipefail

PLUGIN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
. "$PLUGIN_ROOT/lib/state.sh"

SETTINGS="${CLAUDE_SETTINGS:-$HOME/.claude/settings.json}"

# Quick check: are our hooks wired? Use a sentinel file to avoid re-parsing
# settings.json on every keypress (cached after first successful install).
hooks_installed() {
  local cache_dir tag mtime_settings mtime_tag
  cache_dir="$(state::cache_dir)" 2>/dev/null || return 1
  tag="$cache_dir/.hooks-installed"
  if [ -r "$tag" ] && [ -r "$SETTINGS" ]; then
    mtime_settings="$(date -r "$SETTINGS" +%s 2>/dev/null || stat -c %Y "$SETTINGS" 2>/dev/null || echo 0)"
    mtime_tag="$(cat "$tag" 2>/dev/null || echo 0)"
    case "$mtime_tag" in *[!0-9]* | '') mtime_tag=0 ;; esac
    if [ "$mtime_tag" -ge "$mtime_settings" ]; then
      return 0
    fi
  fi
  if [ -r "$SETTINGS" ] \
    && command -v jq >/dev/null 2>&1 \
    && jq -e '
       (.hooks // {}) | to_entries | any(.value | type == "array" and any(
         .hooks // [] | any(.command // "" | contains("tmux-coding-agents/bin/hook"))))
     ' "$SETTINGS" >/dev/null 2>&1; then
    # Cache the verification.
    if [ -n "$cache_dir" ]; then
      mtime_settings="$(date -r "$SETTINGS" +%s 2>/dev/null || stat -c %Y "$SETTINGS" 2>/dev/null || echo 0)"
      printf '%s' "$mtime_settings" >"$tag" 2>/dev/null || true
    fi
    return 0
  fi
  return 1
}

if ! hooks_installed; then
  tmux display-message "tmux-coding-agents: hooks not installed — run: $PLUGIN_ROOT/bin/install-hooks"
  exit 0
fi

# Read tracked panes once under LOCK_SH and snapshot to a tempfile.
#
# SECURITY: every row is filtered through `^%[0-9]+$` on the pane_id column.
# A malformed pane_id is dropped because pane_id is interpolated into tmux
# format strings downstream. State.sh validates writes; this is defense in
# depth against any future regression.
#
# PERFORMANCE: bin/inbox-preview reads from this snapshot file (no flock per
# fzf arrow keypress) instead of calling state::read for every preview render.
# GC of stale rows is handled by bin/inbox-status on its 4-second cooldown,
# not on every popup-open — keeping the keystroke→popup-paint path lock-free
# beyond a single LOCK_SH.
rows="$(state::read 2>/dev/null \
  | awk -F'\t' '$1 ~ /^%[0-9]+$/' || true)"
if [ -z "$rows" ]; then
  tmux display-message "tmux-coding-agents: no Claude sessions tracked yet"
  exit 0
fi

# Hand off to the categorized TUI. The popup runs bin/inbox-popup, which:
#   - reads rows from a file path (passed as argv) — NOT stdin, because the
#     popup's stdin must be the user's keyboard so the TUI can read keys
#   - draws a NEED/WORK/IDLE grouped picker with right-side preview
#   - prints the chosen pane_id to its stdout (empty on cancel)
#
# mktemp without -t (portable across BSD/macOS and GNU).
rows_file="$(mktemp "${TMPDIR:-/tmp}/tca-rows.XXXXXX")"
out_file="$(mktemp "${TMPDIR:-/tmp}/tca-pick.XXXXXX")"
trap 'rm -f "$rows_file" "$out_file"' EXIT
printf '%s\n' "$rows" >"$rows_file"

# Build the inner command. Both file paths are mktemp'd so they're shell-safe;
# we still printf %q to be explicit. The popup binary is also %q-quoted to
# survive any spaces in the plugin-install path.
popup_cmd="$(printf '%q' "$PLUGIN_ROOT/bin/inbox-popup") $(printf '%q' "$rows_file") > $(printf '%q' "$out_file")"
tmux display-popup -E -h 80% -w 90% "$popup_cmd"

selected="$(tr -d '\r\n' <"$out_file" 2>/dev/null || true)"
case "$selected" in
  '') exit 0 ;;
  *)
    if [[ "$selected" =~ ^%[0-9]+$ ]]; then
      tmux switch-client -t "$selected" 2>/dev/null \
        || tmux select-pane -t "$selected" 2>/dev/null \
        || true
    fi
    ;;
esac
