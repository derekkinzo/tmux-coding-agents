#!/usr/bin/env bash
# bin/inbox-popup — interactive inbox picker, powered by fzf.
#
# Reads tracked-pane rows from a file path (argv[1]) and runs fzf with a
# state-grouped list and a live capture-pane preview on the right. On Enter
# the selected pane_id is printed to stdout. Esc / Ctrl-C cancels with
# empty stdout. The caller (bin/inbox-pick) interprets empty stdout as
# "user cancelled".
#
# Why fzf rather than a hand-rolled bash TUI:
#   fzf provides typeahead filtering, native arrow/hjkl navigation, mouse,
#   prompt + footer, an async preview window with toggle, and consistent
#   theming via FZF_DEFAULT_OPTS. Reimplementing those primitives in pure
#   bash produces a worse UX in much more code.
#
# Inputs:
#   $1                 — path to a file holding the TSV rows (no header),
#                        7 columns: pane_id kind status since_epoch pid
#                        project transcript_path
#   stdout             — selected pane_id on Enter; empty on cancel
#
# Required tools: fzf, tmux, awk, sort.

set -uo pipefail

PLUGIN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
. "$PLUGIN_ROOT/lib/render.sh"

if ! command -v fzf >/dev/null 2>&1; then
  printf 'inbox-popup: fzf is required (https://github.com/junegunn/fzf)\n' >&2
  exit 1
fi

rows_file="${1:-}"
if [ -z "$rows_file" ] || [ ! -r "$rows_file" ]; then
  printf 'inbox-popup: rows-file path missing or unreadable\n' >&2
  exit 1
fi

now_epoch="$(date +%s)"

# Build the fzf input. Each line is TAB-separated:
#   col 1: pane_id (or '__hdr__' for section headers)
#   col 2: rendered display text (already ANSI-colored where appropriate)
#
# fzf is invoked with --with-nth=2.. so col 1 is hidden but available via
# {1} in --preview / --bind transforms.
build_fzf_input() {
  local target="$1" label="$2" color="$3" icon="$4"
  local section_rows
  section_rows="$(awk -F'\t' -v t="$target" '$3 == t {
    inv = 9999999999 - $4
    printf "%010d\t%s\n", inv, $0
  }' "$rows_file" | sort -t$'\t' -k1,1n | cut -f2-)"
  if [ -z "$section_rows" ]; then
    return 0
  fi
  # Section header.
  printf '__hdr__\t\033[1;%sm%s\033[0m\n' "$color" "$label"
  # Rows.
  while IFS=$'\t' read -r pane_id _kind _status since _pid project _tpath; do
    [ -n "$pane_id" ] || continue
    local age proj_disp
    case "$since" in '' | *[!0-9]*) since=0 ;; esac
    age="$(render::ago "$((now_epoch - since))")"
    proj_disp="$(printf '%s' "$project" | render::scrub_ansi)"
    # Truncate project to a stable width (45 bytes) for column alignment.
    if [ "${#proj_disp}" -gt 45 ]; then
      proj_disp="$(render::utf8_truncate_bytes "$proj_disp" 44)…"
    fi
    printf '%s\t  \033[%sm%s\033[0m  %-45s  %s\n' \
      "$pane_id" "$color" "$icon" "$proj_disp" "$age"
  done <<<"$section_rows"
}

input="$(
  build_fzf_input waiting NEED '31' '!'
  build_fzf_input working WORK '33' '▶'
  build_fzf_input idle IDLE '90' '·'
)"

if [ -z "$input" ]; then
  printf 'no Claude sessions tracked yet\n' >&2
  exit 0
fi

# fzf options. Bind enter:transform so selecting a section header is a no-op
# (fzf sees `ignore` and stays open). j/k/arrows navigate; q only triggers
# fzf's filter, so we add --bind=q:abort for an explicit exit. The preview
# script is invoked per-row with the pane_id.
sel="$(printf '%s\n' "$input" \
  | fzf \
    --ansi \
    --delimiter=$'\t' \
    --with-nth='2..' \
    --no-sort \
    --layout=reverse \
    --prompt='agents> ' \
    --pointer='›' \
    --header='enter: jump · ?: toggle preview · esc: close' \
    --header-first \
    --preview="bash $(printf '%q' "$PLUGIN_ROOT/bin/inbox-preview") {1}" \
    --preview-window='right:55%:wrap' \
    --bind='?:toggle-preview' \
    --bind='enter:transform:[ {1} = __hdr__ ] && echo ignore || echo accept' \
    --bind='j:down' \
    --bind='k:up' \
    --bind='ctrl-c:abort' \
  || true)"

[ -n "$sel" ] || exit 0

pane_id="$(printf '%s' "$sel" | cut -f1)"
case "$pane_id" in
  __hdr__) exit 0 ;;
  %[0-9]*) printf '%s\n' "$pane_id" ;;
esac
