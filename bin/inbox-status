#!/usr/bin/env bash
# bin/inbox-status — emit the tmux status-bar segment.
#
# Wired by the user via:
#   set -ag status-right ' #(~/.tmux/plugins/tmux-coding-agents/bin/inbox-status)'
#
# tmux re-evaluates this script on every status-interval. The script reads the
# TSV under LOCK_SH, counts states, formats a compact segment with embedded
# tmux #[fg=...] markup. Renders empty when nothing is actionable.
#
# Behavior:
#   - opportunistic GC of dead PIDs while we're here (cheap; runs outside lock
#     by computing alive set first, then handing to state::gc)
#   - never blocks Claude or tmux: lock timeout → emit empty string
#   - all rendered output passes through render::scrub_ansi for terminal-safety

set -uo pipefail

PLUGIN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
. "$PLUGIN_ROOT/lib/state.sh"
# shellcheck disable=SC1091
. "$PLUGIN_ROOT/lib/render.sh"

# Opportunistic GC: drop rows whose claude PID is gone AND rows whose pane
# no longer exists in any tmux session. The picker (bin/inbox-pick) used to
# do the pane-existence sweep on every popup-open, but that put a LOCK_EX
# rewrite on the keystroke→paint path; moving it here keeps the popup
# lock-free and runs cleanup on the status-interval cadence instead.
#
# Cooldown: 4 seconds — slightly under the recommended 5s status-interval so
# we don't run every-other-tick in steady state. state::gc_combined is a
# no-op when alive_panes is empty (no authoritative tmux info), so a
# stalled IPC or no-tmux environment leaves rows untouched.
#
# IPC timeout: tmux list-panes is wrapped with `timeout 1s` where available
# (coreutils / brew) so a stuck tmux server doesn't freeze the status bar
# across all attached clients while the IPC stalls. The wrapper falls back
# to a bare invocation when timeout is missing (busybox / minimal env).
gc_if_due() {
  local cache_dir tag now last
  cache_dir="$(state::cache_dir)" 2>/dev/null || return 0
  tag="$cache_dir/.gc-last"
  now="$(date +%s)"
  last=0
  [ -r "$tag" ] && last="$(cat "$tag" 2>/dev/null || echo 0)"
  case "$last" in *[!0-9]* | '') last=0 ;; esac
  if [ $((now - last)) -lt 4 ]; then
    return 0
  fi
  printf '%s' "$now" >"$tag" 2>/dev/null || true
  local alive live_panes
  alive="$(pgrep -u "$UID" -x claude 2>/dev/null || true)"
  if command -v timeout >/dev/null 2>&1; then
    live_panes="$(timeout 1s tmux list-panes -as -F '#{pane_id}' 2>/dev/null \
      | awk '/^%[0-9]+$/' || true)"
  else
    live_panes="$(tmux list-panes -as -F '#{pane_id}' 2>/dev/null \
      | awk '/^%[0-9]+$/' || true)"
  fi
  state::gc_combined "$alive" "$live_panes" 2>/dev/null || true
}

gc_if_due
state::sweep_orphan_tmps

# Single pass through state::read counts all three statuses in one awk.
# Lock-timeout / corrupt TSV → counts default to 0 (segment empty).
counts="$(state::read 2>/dev/null \
  | awk -F'\t' '
      $3 == "waiting" { w++ }
      $3 == "working" { k++ }
      $3 == "idle"    { i++ }
      END { printf "%d\t%d\t%d", w+0, k+0, i+0 }
    ' 2>/dev/null || printf '0\t0\t0')"
IFS=$'\t' read -r waiting working idle <<<"$counts"
case "$waiting" in *[!0-9]* | '') waiting=0 ;; esac
case "$working" in *[!0-9]* | '') working=0 ;; esac
case "$idle" in *[!0-9]* | '') idle=0 ;; esac

# Optional user-defined format. When @inbox-status-format is set, render::status
# substitutes {NEED}/{WORK}/{IDLE}/{TOTAL} placeholders and emits the template
# even when all counts are 0 (persistent badge mode).
fmt=""
if command -v tmux >/dev/null 2>&1; then
  fmt="$(tmux show-option -gqv '@inbox-status-format' 2>/dev/null || true)"
fi

# Pass output through render::scrub_ansi: defense against any control
# bytes that might have slipped through.
render::status "$waiting" "$working" "$idle" "$fmt" | render::scrub_ansi
exit 0
