#!/usr/bin/env bash
# bin/uninstall-hooks — remove tmux-coding-agents from ~/.claude/settings.json.
#
# Filters out any hook whose command references our hook binary, then writes
# back. Backs up first.
#
# Concurrency: flocks the same sidecar lock as bin/install-hooks so the two
# cannot interleave.
#
# Note on restore: this script REMOVES our entries in-place. If a user wants
# the original file back, they should use one of the .bak.* files left by
# install-hooks. (We deliberately do not auto-restore from .bak because the
# most-recent .bak may itself be from a prior install, not the original.)

set -euo pipefail

PLUGIN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
HOOK_BIN="$PLUGIN_ROOT/bin/hook"
SETTINGS="${CLAUDE_SETTINGS:-$HOME/.claude/settings.json}"

err() {
  printf 'uninstall-hooks: %s\n' "$*" >&2
}

if ! command -v jq >/dev/null 2>&1; then
  err "jq is required"
  exit 1
fi

if [ ! -f "$SETTINGS" ]; then
  err "$SETTINGS not found; nothing to do"
  exit 0
fi

if ! jq -e . "$SETTINGS" >/dev/null 2>&1; then
  err "$SETTINGS is not valid JSON; refusing to modify"
  exit 1
fi

# If there's nothing of ours, exit early without backup churn. We match either
# the default-path substring or the absolute hook path (covers alt-install dirs).
if ! jq -e --arg hook "$HOOK_BIN" '
  (.hooks // {})
  | to_entries
  | any(
      .value | (
        if type == "array" then .[] | (.hooks // [])[]?
        elif type == "object" then to_entries[] | .value[]?
        else empty
        end
      ) | (.command // "") | (contains("tmux-coding-agents/bin/hook") or contains($hook))
    )
' "$SETTINGS" >/dev/null 2>&1; then
  printf 'tmux-coding-agents: nothing to remove from %s\n' "$SETTINGS"
  exit 0
fi

# Lock.
lock="$SETTINGS.lock"
exec 200>>"$lock"
if ! flock -w 5 -x 200; then
  err "could not acquire lock on $lock within 5s"
  exit 1
fi
trap 'flock -u 200 2>/dev/null; rm -f "$tmp" 2>/dev/null' EXIT

# Backup.
backup="$SETTINGS.bak.$(date +%s).$$"
cp -n "$SETTINGS" "$backup" 2>/dev/null || cp "$SETTINGS" "$backup"

# tmpfile in same dir for atomic mv.
tmp="$(mktemp "$(dirname "$SETTINGS")/.settings.json.XXXXXX")"
chmod --reference="$SETTINGS" "$tmp" 2>/dev/null || chmod 0600 "$tmp"

jq --arg hook "$HOOK_BIN" '
  def is_ours(cmd):
    cmd as $c
    | (($c // "") | contains("tmux-coding-agents/bin/hook"))
      or (($c // "") | contains($hook));

  def normalize_event_value(v):
    if v == null then []
    elif (v | type) == "array" then
      v | map(
        if (. | type) == "object" and (.hooks | type) == "array"
          then . + {matcher: (.matcher // "")}  # preserve sibling fields
        else empty
        end
      )
    elif (v | type) == "object" then
      v | to_entries | map({
        matcher: .key,
        hooks: (if (.value | type) == "array" then .value else [] end)
      })
    else []
    end;

  def filter_ours(arr):
    arr | map(
      .hooks = (.hooks | map(select((is_ours(.command)) | not)))
    ) | map(select((.hooks | length) > 0));

  if (.hooks | type) != "object" then .
  else
    .hooks = (
      .hooks
      | with_entries(.value = filter_ours(normalize_event_value(.value)))
      | with_entries(select((.value | length) > 0))
    )
  end
' "$SETTINGS" > "$tmp"

if ! jq -e . "$tmp" >/dev/null 2>&1; then
  err "filter produced invalid JSON; aborting (backup at $backup)"
  exit 1
fi

mv -f "$tmp" "$SETTINGS"
trap 'flock -u 200 2>/dev/null' EXIT

cat <<EOF
tmux-coding-agents: hooks removed from $SETTINGS
                    backup at $backup
EOF
