#!/usr/bin/env bash
# tests/mocks/tmux — bats stub for tmux invocations.
#
# Records every invocation to $BATS_TEST_TMPDIR/tmux.calls (one line per call)
# and answers a small subset of subcommands with canned data:
#
#   tmux -V                                  → "tmux 3.4"
#   tmux display-message -p '#{pane_id}'     → ${MOCK_PANE_ID:-%17}
#   tmux display-message -p -t X '#{pane_pid}' → ${MOCK_PANE_PID:-12345}
#   tmux show-option -gqv @<key>             → looks up MOCK_OPT_<key> env var
#   anything else                            → silent success
#
# Tests can preset MOCK_* env vars before invocation. Tests can read
# $BATS_TEST_TMPDIR/tmux.calls to assert call shapes.

CALLS_FILE="${BATS_TEST_TMPDIR:-/tmp}/tmux.calls"
{
  printf '%q ' "$@"
  printf '\n'
} >>"$CALLS_FILE" 2>/dev/null || true

# Dispatch.
case "${1:-}" in
  -V)
    echo "tmux ${MOCK_TMUX_VERSION:-3.4}"
    exit 0
    ;;
  display-message)
    # We support both: `tmux display-message -p ...` (read) and `tmux display-message <text>` (notify).
    shift
    has_p=0
    target=""
    fmt=""
    while [ $# -gt 0 ]; do
      case "$1" in
        -p) has_p=1 ;;
        -t) shift; target="$1" ;;
        *) fmt="$1" ;;
      esac
      shift
    done
    if [ "$has_p" = 1 ]; then
      case "$fmt" in
        '#{pane_id}') echo "${MOCK_PANE_ID:-%17}" ;;
        '#{pane_pid}') echo "${MOCK_PANE_PID:-12345}" ;;
        *) echo "" ;;
      esac
    fi
    # Notify form is silent.
    exit 0
    ;;
  show-option)
    # tmux show-option -gqv @key
    shift
    while [ $# -gt 0 ] && [ "${1:0:1}" = "-" ]; do shift; done
    key="${1:-}"
    # Sanitize key for env var name.
    var_key="MOCK_OPT_$(printf '%s' "$key" | tr '@-' '__')"
    eval "echo \"\${$var_key:-}\""
    exit 0
    ;;
  set-option|set-environment|bind-key|run-shell|refresh-client|switch-client|select-pane)
    exit 0
    ;;
  *)
    exit 0
    ;;
esac
